# Copy this file to .env (at project root) and fill in your values
SUPABASE_URL=https://your-project-id.supabase.co

# Legacy service_role key (JWT starting with "eyJ...")
# Supabase Dashboard → Project Settings → API Keys
#   → "Legacy anon, service_role API keys" tab → service_role row
# NOTE: supabase-py requires JWT format — new sb_secret_... keys are not yet supported
SUPABASE_SECRET_KEY=your-service-role-jwt-key-here

# Publishable/anon key — safe to expose to the browser (used by Supabase Auth JS)
# Supabase Dashboard → Project Settings → API Keys → "anon" (publishable) key
SUPABASE_ANON_KEY=your-anon-key-here
